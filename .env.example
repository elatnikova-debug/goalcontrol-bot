# Токен бота (получить у @BotFather в Telegram)
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Ключ OpenAI API для анализа личности (GPT-4o)
# Получить: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Цена подписки в Telegram Stars (по умолчанию 250 ≈ $5)
SUBSCRIPTION_PRICE_STARS=250

# Длительность подписки в днях (по умолчанию 30)
SUBSCRIPTION_DAYS=30

# Путь к файлу базы данных (по умолчанию coach_bot.db)
DB_PATH=coach_bot.db
